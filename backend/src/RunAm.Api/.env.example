# ================================================
# RunAm Backend Environment Variables
# ================================================
# Copy this file to .env and fill in the values.
# The .env file is gitignored and should NEVER be committed.
# ================================================

# ---------- Database ----------
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_NAME=runam
DATABASE_USER=runam
DATABASE_PASSWORD=runam_dev_password

# ---------- Redis ----------
REDIS_CONNECTION=localhost:6380

# ---------- JWT Authentication ----------
JWT_SECRET_KEY=your-secret-key-at-least-32-characters-long
JWT_ISSUER=RunAm
JWT_AUDIENCE=RunAm
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# ---------- Seq Logging ----------
SEQ_SERVER_URL=http://localhost:5341

# ---------- ZeptoMail (Transactional Email) ----------
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=noreply@runam.app
ZEPTOMAIL_FROM_NAME=RunAm

# ---------- Termii (SMS / OTP) ----------
TERMII_API_KEY=
TERMII_SENDER_ID=RunAm

# ---------- Payment Gateway (Monnify) ----------
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_SOURCE_ACCOUNT_NUMBER=
MONNIFY_WEBHOOK_SECRET=

# ---------- Delivery Pricing ----------
DELIVERY_BASE_FARE=500
DELIVERY_PER_KM_RATE=100

# ---------- File Storage (Cloudinary) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- RabbitMQ ----------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=runam
RABBITMQ_PASSWORD=runam_dev_password

# ---------- Firebase Cloud Messaging ----------
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# ---------- Google Maps ----------
GOOGLE_MAPS_API_KEY=

# ---------- Application ----------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5001
